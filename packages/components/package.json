{
  "name": "@dds/emerald",
  "version": "0.1.0",
  "description": "Emerald component library by Digital Dev Studio",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "lucide-react": "^1.7.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@dds/emerald-tokens": "workspace:*",
    "@dds/eslint-config": "workspace:*",
    "@dds/typescript-config": "workspace:*",
    "@dds/vitest-config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@radix-ui/react-avatar": "^1.x.x",
    "@radix-ui/react-slot": "^1.x.x",
    "@radix-ui/react-visually-hidden": "^1.x.x",
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.x.x",
    "lucide-react": "^1.7.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "sass": "^1.x.x",
    "typescript": "^5.x.x",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@dds/emerald-tokens": "workspace:*",
    "clsx": "^2.x.x"
  }
}
